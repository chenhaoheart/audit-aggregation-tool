\\n        self.update()\\\\n        super().leaveEvent(event)\\\\n\\\\n    def mousePressEvent(self, event):\\\\n        if event.button() == Qt.LeftButton:\\\\n            self.clicked.emit(self.group)\\\\n        super().mousePressEvent(event)\\\\n\\\\n    def paintEvent(self, event):\\\\n        painter = QPainter(self)\\\\n        painter.setRenderHint(QPainter.Antialiasing)\\\\n\\\\n        rect = self.rect().adjusted(1, 1, -1, -1)\\\\n        radius = 14\\\\n\\\\n        gradient = QLinearGradient(0, 0, self.width(), self.height())\\\\n        if self.group == ThemeGroup.LIGHT:\\\\n            gradient.setColorAt(0, QColor(\\\\\\\"#FFE8D6\\\\\\\"))\\\\n            gradient.setColorAt(0.5, QColor(\\\\\\\"#FFF5EF\\\\\\\"))\\\\n            gradient.setColorAt(1, QColor(\\\\\\\"#FDE8FF\\\\\\\"))\\\\n        else:\\\\n            gradient.setColorAt(0, QColor(\\\\\\\"#0a0e27\\\\\\\"))\\\\n            gradient.setColorAt(0.5, QColor(\\\\\\\"#141b3d\\\\\\\"))\\\\n            gradient.setColorAt(1, QColor(\\\\\\\"#1a1a2e\\\\\\\"))\\\\n\\\\n        painter.setBrush(QBrush(gradient))\\\\n        painter.setPen(QPen(Qt.NoPen))\\\\n        painter.drawRoundedRect(rect, radius, radius)\\\\n\\\\n        if self._selected:\\\\n            pen = QPen(QColor(\\\\\\\"#6366f1\\\\\\\" if self.group == ThemeGroup.LIGHT else \\\\\\\"#818cf8\\\\\\\"), 2.5)\\\\n            painter.setPen(pen)\\\\n            painter.drawRoundedRect(QRect(rect.x() + 1, rect.y() + 1,\\\\n                                          rect.width() - 3, rect.height() - 3), radius - 1, radius - 1)\\\\n\\\\n        if self._hover and not self._selected:\\\\n            painter.setPen(QPen(QColor(255, 255, 255, 160) if self.group == ThemeGroup.DARK\\\\n                               else QColor(100, 80, 60, 80), 1))\\\\n            painter.drawRoundedRect(QRect(rect.x(), rect.y(), rect.width() - 1, rect.height() - 1), radius, radius)\\\\n\\\\n        text_color = QColor(\\\\\\\"#7a5b3a\\\\\\\") if self.group ==