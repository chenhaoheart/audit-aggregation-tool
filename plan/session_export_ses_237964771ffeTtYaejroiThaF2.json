lor = QColor(\\\"#4a3520\\\") if self.group == ThemeGroup.LIGHT else QColor(\\\"#ffffff\\\")\\n        painter.setPen(QPen(name_color))\\n        painter.drawText(rect.adjusted(48, 8, -12, -40), Qt.AlignLeft | Qt.AlignVCenter, self._name)\\n\\n        sub_font = QFont()\\n        sub_font.setPointSize(10)\\n        painter.setFont(sub_font)\\n        sub_color = QColor(\\\"#8d6e63\\\") if self.group == ThemeGroup.LIGHT else QColor(\\\"#7986cb\\\")\\n        painter.setPen(QPen(sub_color))\\n        theme_count = len(THEME_GROUP_MAP[self.group][\\\"modes\\\"])\\n        painter.drawText(rect.adjusted(48, 32, -12, -8),\\n                         Qt.AlignLeft | Qt.AlignVCenter,\\n                         f\\\"{self._subtitle}  {theme_count}绉嶉鏍糪\\")\\n\\n        painter.end()\\n\\n\\nclass _GlassOpacitySlider(QFrame):\\n    \\\"\\\"\\\"姣涚幓鐠冧笉閫忔槑搴︽粦鍧梊\\"\\\"\\\"\\n\\n    opacity_changed = Signal(float)\\n\\n    def __init__(self, parent=None):\\n        super().__init__(parent)\\n        layout = QVBoxLayout()\\n        layout.setContentsMargins(0, 8, 0, 4)\\n        layout.setSpacing(8)\\n\\n        header = QHBoxLayout()\\n        header.setSpacing(12)\\n\\n        icon = QLabel(\\\"\\\\U0001fa9f\\\")\\n        icon.setStyleSheet(\\\"font-size: 18px; background: transparent;\\\")\\n        header.addWidget(icon)\\n\\n        title = QLabel(\\\"姣涚幓鐠冮€忔槑搴\\")\\n        title.setObjectName(\\\"sectionHeaderSm\\\")\\n        header.addWidget(title)\\n\\n        self._pct_label = QLabel()\\n        self._pct_label.setObjectName(\\\"secondaryLabel\\\")\\n        self._pct_label.setFixedWidth(42)\\n        self._pct_label.setAlignment(Qt.AlignRight | Qt.AlignVCenter)\\n        header.addStretch()\\n        header.addWidget(self._pct_label)\\n        layout.addLayout(header)\\n\\n        self._slider = QSlider(Qt.Horizontal)\\n        self._slider.setMinimum(10)\\n        self._slider.setMaximum(100)\\n        self._slider.setSingleStep(5)\\n        self._slider.setPageStep(